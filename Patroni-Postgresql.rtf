\b0 global\par
  maxconn 100\par
  log     127.0.0.1 local2\par
defaults\par
  log global\par
  mode tcp\par
  retries 2\par
  timeout client 30m\par
  timeout connect 4s\par
  timeout server 30m\par
  timeout check 5s\par
